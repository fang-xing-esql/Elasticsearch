inSubqueryWithInlineStatsAfterInSubqueryWithNull
required_capability: in_subquery

FROM employees
| WHERE first_name IN (FROM employees | KEEP first_name)
| INLINE STATS cnt = COUNT(*)
| KEEP cnt
| LIMIT 1
;

cnt:integer
90
;

inSubqueryWithInlineStatsBeforeAndAfterInSubquery
required_capability: in_subquery

FROM employees
| INLINE STATS cnt1 = COUNT(*) BY gender
| WHERE first_name IN (FROM employees | WHERE salary < 30000 | KEEP first_name)
| INLINE STATS cnt2 = COUNT(*)
| KEEP first_name, salary, cnt1, cnt2
| SORT salary DESC
;

first_name:keyword | salary:integer | cnt1:long | cnt2:long
Breannda           | 29175          | 57        | 8
