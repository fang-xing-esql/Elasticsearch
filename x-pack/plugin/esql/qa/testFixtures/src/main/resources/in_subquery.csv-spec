10094          | 66817
10099          | 73578
;

inSubqueryWithInlineStatsBeforeInSubquery
required_capability: in_subquery

FROM employees
| INLINE STATS cnt = COUNT(*) BY gender
| WHERE first_name IN (FROM employees | WHERE salary < 30000 | KEEP first_name)
| KEEP first_name, salary, cnt
| SORT salary DESC
;

