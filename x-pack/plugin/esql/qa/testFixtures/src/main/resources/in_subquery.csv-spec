//
// CSV spec for IN and NOT IN subqueries
//

basicInSubquery
required_capability: in_subquery

FROM employees
| WHERE emp_no IN (FROM employees | SORT emp_no ASC | LIMIT 3 | KEEP emp_no)
| SORT emp_no
| KEEP emp_no, first_name
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

basicNotInSubquery
required_capability: in_subquery

FROM employees
| WHERE emp_no NOT IN (FROM employees | SORT emp_no ASC | LIMIT 3 | KEEP emp_no)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10004          | Chirstian
10005          | Kyoichi
10006          | Anneke
;

inSubqueryEmptyResults
required_capability: in_subquery

FROM employees
| WHERE emp_no IN (FROM employees | WHERE salary > 100000 | KEEP emp_no)
| SORT emp_no
| KEEP emp_no
;

emp_no:integer
;

notInSubqueryEmptyResults
required_capability: in_subquery

FROM employees
| WHERE emp_no NOT IN (FROM employees | WHERE salary < 10000 | KEEP emp_no)
| SORT emp_no
| KEEP emp_no
| LIMIT 3
;

emp_no:integer
10001
10002
10003
;

inSubqueryWithStatsInsideInSubquery
required_capability: in_subquery

FROM employees
| WHERE salary IN (FROM employees | STATS m = max(salary) by languages | KEEP m)
| KEEP emp_no, salary
| SORT emp_no
;

emp_no:integer | cnt:integer
10007          | 74572
10019          | 73717
10029          | 74999
10045          | 74970
10094          | 66817
10099          | 73578
;

inSubqueryWithStatsBeforeInSubquery
required_capability: in_subquery

FROM employees
| STATS cnt = COUNT(*) BY gender
| WHERE gender IN (FROM employees | KEEP gender)
| STATS cnt = COUNT(*)
;

cnt:integer
2
;

inSubqueryWithStatsAfterInSubqueryWithNull
required_capability: in_subquery

FROM employees
| WHERE first_name IN (FROM employees | KEEP first_name)
| STATS cnt = COUNT(*)
;

cnt:integer
90
;

inSubqueryWithInlineStatsInsideInSubquery
required_capability: in_subquery

FROM employees
| WHERE salary IN (FROM employees | INLINE STATS m = max(salary) by languages | KEEP m)
| KEEP emp_no, salary
| SORT emp_no
;

emp_no:integer | cnt:integer
