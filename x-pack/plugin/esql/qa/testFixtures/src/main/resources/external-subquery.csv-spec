// Subqueries inside a FROM command whose source is an inline EXTERNAL data source, e.g.
//   FROM employees, (EXTERNAL "{{employees}}" | WHERE salary > 50000)
//
// Picked up by AbstractExternalSourceSpecTestCase subclasses (ParquetFormatSpecIT, OrcFormatSpecIT,
// CsvFormatSpecIT, NdJsonFormatSpecIT, ...) via the `/external-*.csv-spec` glob — each test fires
// once per storage backend (S3/HTTP/GCS/Azure/LOCAL) and once per configured format/codec.
//
// Every test gates on `subquery_in_from_command_with_external_data_source`: until the grammar adds
// `externalCommand` to `subquerySourceCommand` (and the capability flips on), every test in this
// file is skipped by the capabilities pre-check.

subqueryExternalBasic
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM employees,
     (EXTERNAL "{{employees}}")
| WHERE emp_no >= 10091 AND emp_no < 10094
| KEEP emp_no, languages
| SORT emp_no
;

emp_no:integer | languages:integer
10091          | 3
10091          | 3
10092          | 1
10092          | 1
10093          | 3
10093          | 3
;

