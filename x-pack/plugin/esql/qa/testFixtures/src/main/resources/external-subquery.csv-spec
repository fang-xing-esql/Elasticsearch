subqueryExternalWithWhereInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | WHERE salary > 70000
      | KEEP emp_no, salary)
| SORT salary DESC, emp_no
;

emp_no:integer | salary:integer
10029          | 74999
10045          | 74970
10007          | 74572
10027          | 73851
10019          | 73717
10099          | 73578
10097          | 71165
10033          | 70011
;

subqueryExternalWithEvalInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | EVAL bonus = round(salary * 0.1, 1)
      | KEEP emp_no, salary, bonus)
| WHERE emp_no >= 10091 AND emp_no < 10094
| SORT emp_no
;

emp_no:integer | salary:integer | bonus:double
10091          | 38645          | 3864.5
10092          | 25976          | 2597.6
10093          | 45656          | 4565.6
;

subqueryExternalWithStatsInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | STATS avg_salary = AVG(salary), cnt = COUNT(*) BY gender)
| SORT gender
;

avg_salary:double    | cnt:long | gender:keyword
50490.78787878788    | 33       | F
46860.59649122807    | 57       | M
48760.5              | 10       | null
;

subqueryExternalWithSortAndLimitInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | SORT salary DESC
      | LIMIT 3
      | KEEP emp_no, salary)
| SORT salary DESC
;

emp_no:integer | salary:integer
10029          | 74999
10045          | 74970
10007          | 74572
;

subqueryExternalWithDissectInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | EVAL full_name = CONCAT(first_name, " ", last_name)
      | DISSECT full_name "%{fn} %{ln}"
      | KEEP emp_no, fn)
| WHERE emp_no >= 10001 AND emp_no <= 10003
| SORT emp_no
;

emp_no:integer | fn:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

subqueryExternalWithMvExpandInSubquery
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM (EXTERNAL "{{employees}}"
      | MV_EXPAND job_positions
      | KEEP emp_no, job_positions)
| WHERE emp_no == 10001
| SORT job_positions
;

emp_no:integer | job_positions:keyword
10001          | Accountant
10001          | Senior Python Developer
;

