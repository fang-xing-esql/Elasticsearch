subqueryExternalCombineWithEsIndex
required_capability: subquery_in_from_command
required_capability: external_command
required_capability: subquery_in_from_command_with_external_data_source

FROM sample_data,
     (EXTERNAL "{{employees}}"
      | WHERE emp_no >= 10091 AND emp_no < 10094
      | KEEP emp_no, languages)
| WHERE (emp_no >= 10091 AND emp_no < 10094) OR emp_no IS NULL
| SORT emp_no, client_ip
| KEEP emp_no, languages, client_ip
;

